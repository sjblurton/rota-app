{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-lintignore"],
  "workspaces": {
    ".": {
      "ignore": ["client/**"],
      "ignoreDependencies": [
        "@typescript-eslint/eslint-plugin",
        "@typescript-eslint/parser",
        "lint-staged"
      ]
    },
    "server": {
      "ignoreBinaries": ["psql"],
      "ignoreDependencies": [
        "jiti",
        "pino-pretty",
        "@prisma/client",
        "@types/pino-http",
        "@types/pg",
        "pg",
        "jose"
      ]
    }
  }
}
