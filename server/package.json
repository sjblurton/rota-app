{
  "scripts": {
    "lint:eslint": "eslint --fix .",
    "lint:typescript": "tsc --noEmit",
    "lint": "npm run lint:eslint && npm run lint:typescript",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage --config vitest.coverage.config.ts",
    "prepare": "cd .. && npx --prefix ./server husky",
    "format": "prettier --write .",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=prisma/schema.prisma",
    "db:reset:force": "prisma migrate reset --force --schema=prisma/schema.prisma && npm run db:seed",
    "db:studio": "prisma studio --config=./prisma.config.ts",
    "db:seed": "prisma db seed",
    "db:reset:seed": "npm run db:reset && npm run db:seed",
    "db:format": "prisma format --schema=prisma/schema.prisma",
    "check:all": "npm run lint && npm run test:coverage && npm run db:format && npm run format"
  },
  "lint-staged": {
    "src/**/*.{js,mjs,cjs,ts,mts,cts}": [
      "eslint --fix",
      "prettier --write",
      "prisma format --schema=prisma/schema.prisma"
    ]
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@supabase/supabase-js": "^2.103.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "execa": "^9.6.1",
    "express": "^5.2.1",
    "jose": "^6.2.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/pino-http": "^5.8.4",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.57.1",
    "eslint-plugin-boundaries": "^6.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^53.0.0",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  }
}
